# ============================================================
# UPL - Pokemon Draft League  |  Environment Variables
# ============================================================
# Copy this file to .env and fill in real values.
# Never commit .env to version control.

# ----------------------------------------------------------
# Database
# ----------------------------------------------------------
# Local dev (Docker):
#   DATABASE_URL=postgresql+pg8000://upl:upl@localhost:5432/upl
# Railway (auto-set from Postgres plugin, but must use pg8000 dialect):
#   DATABASE_URL=postgresql+pg8000://<user>:<pass>@<host>:<port>/<db>
DATABASE_URL=postgresql+pg8000://upl:upl@localhost:5432/upl

# ----------------------------------------------------------
# Auth / JWT
# ----------------------------------------------------------
# Generate a strong random key: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=your-secret-key-here-change-in-production
ALGORITHM=HS256
# Token lifetime in minutes (default 7 days)
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# ----------------------------------------------------------
# CORS
# ----------------------------------------------------------
# Comma-separated list of allowed frontend origins.
# In Railway: set to your frontend domain, e.g. https://upl.up.railway.app
ALLOWED_ORIGINS=http://localhost:5173

# ----------------------------------------------------------
# Email (SMTP) — optional, used for notifications
# ----------------------------------------------------------
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
# Use a Gmail App Password (not your login password)
SMTP_PASS=your-app-password

# ----------------------------------------------------------
# Discord Webhooks — optional, used for event notifications
# ----------------------------------------------------------
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/your-webhook-url

# ----------------------------------------------------------
# Environment
# ----------------------------------------------------------
# "development" → human-readable logs
# "production"  → structured JSON logs
ENVIRONMENT=development
